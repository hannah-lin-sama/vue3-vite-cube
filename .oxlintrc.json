{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "vue", "vitest"],
  "env": {
    "browser": true
  },
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["dist/", "node_modules/"],
  "rules": {
    "unicorn/quote-style": "off",
    "quotes": ["error", "single"]
  }
}
